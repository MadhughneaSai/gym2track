# Copy to functions/.env. No secrets live here — the DeepSeek API key is stored
# in Firebase Secret Manager (firebase functions:secrets:set DEEPSEEK_API_KEY).
#
# DeepSeek model for the AI Coach. Change this line + redeploy to switch models.
#   deepseek-v4-flash → thinking mode, cheap
#   deepseek-v4-pro   → deeper reasoning, ~3× output cost
#   deepseek-chat     → faster non-thinking flash
DEEPSEEK_MODEL=deepseek-chat
