# Copy to functions/.env. No secrets live here — the DeepSeek API key is stored
# in Firebase Secret Manager (firebase functions:secrets:set DEEPSEEK_API_KEY).
#
# DeepSeek models for the AI Coach. Change a line + redeploy to switch.
# Chat answers run with thinking forced ON at MAXIMUM effort (set in index.js), so pick a
# reasoning-capable model here:
#   deepseek-v4-pro   → deepest reasoning, ~3× output cost
#   deepseek-v4-flash → thinking, cheaper
DEEPSEEK_MODEL=deepseek-v4-pro
# Background memory extraction — kept on a FAST non-thinking model so it never adds reasoning
# latency to your turn. (deepseek-chat = non-thinking v4-flash; deprecates 2026-07-24.)
DEEPSEEK_EXTRACT_MODEL=deepseek-chat
