rules_version = '2';

// Each signed-in user can read/write ONLY their own subtree: users/{their-uid}/**.
// Nobody can touch anyone else's data, even though it's one shared database.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ---- OPTIONAL: invite-only (cap to your ~10 people) ----
    // Replace the block above with this one and fill in the emails to refuse
    // sign-ups from anyone not on the list. Google sign-in still works for them,
    // but they get permission-denied and see no data.
    //
    // function allowed() {
    //   return request.auth != null && request.auth.token.email in [
    //     'you@gmail.com',
    //     'friend@gmail.com'
    //   ];
    // }
    // match /users/{uid}/{document=**} {
    //   allow read, write: if allowed() && request.auth.uid == uid;
    // }
  }
}
